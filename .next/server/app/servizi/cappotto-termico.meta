{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/servizi/layout,_N_T_/servizi/[slug]/layout,_N_T_/servizi/[slug]/page,_N_T_/servizi/cappotto-termico/"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/servizi/$d$slug/__PAGE__",
    "/servizi/$d$slug",
    "/servizi",
    "/_index",
    "/_head"
  ]
}