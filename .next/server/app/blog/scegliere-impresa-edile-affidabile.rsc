22:["$","p","8",{"className":"text-gray-700 leading-relaxed mb-4","children":"Un professionista serio:\n- Visita il cantiere prima di fare il preventivo\n- Fa domande precise sulle tue esigenze\n- Ti spiega le varie fasi dei lavori\n- Ti indica eventuali problemi o criticità"}]
23:["$","h2","9",{"className":"text-2xl font-bold text-navy mt-8 mb-4","children":"Il contratto"}]
24:["$","p","10",{"className":"text-gray-700 leading-relaxed mb-4","children":"Il contratto di appalto deve contenere:\n- Descrizione dettagliata dei lavori\n- Elenco dei materiali con specifiche tecniche\n- Prezzi unitari e prezzo totale\n- Tempi di inizio e fine lavori\n- Modalità di pagamento (mai anticipi troppo alti!)\n- Penali per ritardi\n- Garanzie sui lavori"}]
25:["$","h2","11",{"className":"text-2xl font-bold text-navy mt-8 mb-4","children":"Segnali di allarme"}]
26:["$","p","12",{"className":"text-gray-700 leading-relaxed mb-4","children":"Stai alla larga da chi:\n- Non vuole fare un contratto scritto\n- Chiede pagamenti in contanti o in nero\n- Non ha una sede o un recapito fisso\n- Ti chiede anticipi superiori al 30%\n- Non ti fornisce referenze verificabili\n- Ti promette tempi troppo brevi"}]
