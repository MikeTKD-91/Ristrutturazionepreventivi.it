6:["$","p","5",{"className":"text-gray-700 leading-relaxed mb-4","children":"**Top cucina**:\n- Laminato: economico, facile da pulire\n- Quarzo: resistente, non poroso, molte tonalità\n- Granito: naturale, resistente al calore\n- Okite: simile al quarzo, buon rapporto qualità-prezzo\n- Legno: caldo, ma richiede manutenzione"}]
7:["$","p","6",{"className":"text-gray-700 leading-relaxed mb-4","children":"**Ante mobili**:\n- Laccato lucido: moderno, facile da pulire\n- Laccato opaco: elegante, nasconde le ditate\n- Legno: caldo e naturale\n- Vetro: moderno e luminoso\n- Melaminico: economico e resistente"}]
8:["$","p","7",{"className":"text-gray-700 leading-relaxed mb-4","children":"**Pavimenti**:\n- Gres porcellanato: il più resistente e facile da pulire\n- Parquet: caldo, ma meno pratico in cucina\n- Resina: moderna, senza giunture"}]
9:["$","h2","8",{"className":"text-2xl font-bold text-navy mt-8 mb-4","children":"Illuminazione"}]
a:["$","p","9",{"className":"text-gray-700 leading-relaxed mb-4","children":"Una cucina ben illuminata richiede:\n- Luce generale (plafoniere o faretti)\n- Luce sul piano lavoro (sottopensile)\n- Luce d'atmosfera (sopra l'isola o la penisola)\n- Luce all'interno delle vetrine e dei pensili"}]
b:["$","h2","10",{"className":"text-2xl font-bold text-navy mt-8 mb-4","children":"Impianti da verificare"}]
c:["$","p","11",{"className":"text-gray-700 leading-relaxed mb-4","children":"In una ristrutturazione cucina è fondamentale:\n- Aumentare le prese elettriche (almeno 6-8 punti)\n- Verificare la potenza del contratto elettrico\n- Installare interruttori differenziali dedicati\n- Verificare il diametro dei tubi del gas\n- Controllare lo scarico del lavello"}]
d:["$","h2","12",{"className":"text-2xl font-bold text-navy mt-8 mb-4","children":"Costi indicativi 2026"}]
e:["$","p","13",{"className":"text-gray-700 leading-relaxed mb-4","children":"Per una cucina di 10-12 mq:\n- **Finitura Base**: da 4.000 € a 6.000 €\n- **Finitura Standard**: da 7.000 € a 12.000 €\n- **Finitura Premium**: da 12.000 € a 20.000 €"}]
f:["$","p","14",{"className":"text-gray-700 leading-relaxed mb-4","children":"I prezzi includono: demolizioni, rifacimento impianti, pavimenti, rivestimenti, mobili cucina, elettrodomestici base, illuminazione e manodopera."}]
